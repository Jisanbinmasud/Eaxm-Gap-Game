rules_version = '2';

// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: teams
// Fields:
//   - id: string (required)
//   - name: string (required, 1-50 chars)
//   - logo: string (required, 1-10 chars)
//   - points: number (required, >= 0)
//   - wins: number (required, >= 0)
//   - matchesPlayed: number (required, >= 0)
//
// Collection: matches
// Fields:
//   - id: string (required)
//   - stage: string (required, enum)
//   - team1Id: string (optional)
//   - team2Id: string (optional)
//   - winnerId: string (optional)
//   - nextMatchId: string (optional)
//   - bestOf: number (required, 1 or 3)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "jisanbinmasud@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidTeam(data) {
      return data.keys().hasAll(['id', 'name', 'logo', 'points', 'wins', 'matchesPlayed']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 50 &&
             data.logo is string && data.logo.size() >= 1 && data.logo.size() <= 10 &&
             data.points is number && data.points >= 0 &&
             data.wins is number && data.wins >= 0 &&
             data.matchesPlayed is number && data.matchesPlayed >= 0;
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['id', 'stage', 'bestOf']) &&
             data.stage in ['QUARTER-FINALS', 'SEMI-FINALS', 'FINALS'] &&
             data.bestOf in [1, 3] &&
             (!('team1Id' in data) || data.team1Id is string || data.team1Id == null) &&
             (!('team2Id' in data) || data.team2Id is string || data.team2Id == null) &&
             (!('winnerId' in data) || data.winnerId is string || data.winnerId == null);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if true;
      allow write: if isAdmin() && isValidTeam(request.resource.data);
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin() && isValidMatch(request.resource.data);
    }
  }
}
